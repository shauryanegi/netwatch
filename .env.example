# ─────────────────────────────────────────────
#  netwatch — environment configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Required for AI features (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: where to store the SQLite database
# Default: ~/.netwatch/data.db
# NETWATCH_DB_PATH=/path/to/your/data.db

# Optional: minutes between automatic speed tests in daemon mode
# Default: 15
# NETWATCH_INTERVAL=15

# Optional: your ISP name (used in complaint letters)
# Default: My ISP
# NETWATCH_ISP_NAME=Comcast

# Optional: your advertised plan speed in Mbps (used in complaint letters)
# Default: 100
# NETWATCH_ADVERTISED_MBPS=200

# Optional: Groq model to use (default is fast and free)
# Default: llama3-8b-8192
# GROQ_MODEL=llama3-70b-8192
